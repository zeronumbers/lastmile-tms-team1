# ===== Compose =====
# Activate dev-only services (remove or leave empty in production)
COMPOSE_PROFILES=dev

# ===== Database =====
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=lastmile_tms;Username=postgres;Password=postgres

# ===== Hangfire =====
HANGFIRE_CONNECTION_STRING=Host=postgres;Port=5432;Database=lastmile_tms;Username=postgres;Password=postgres

# ===== Redis =====
REDIS_CONNECTION_STRING=redis:6379

# ===== Seq (Logging) =====
SEQ_FIRSTRUN_ADMINPASSWORD=1234

# ===== Admin User (seeded on startup) =====
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@lastmile.com
ADMIN_PASSWORD=Admin@123

# ===== NextAuth =====
# NEXTAUTH_URL must match the deployment URL (e.g., http://localhost for local dev, or https://your-domain.com in production)
NEXTAUTH_URL=http://localhost
# Generate a new secret with: openssl rand -base64 32
AUTH_SECRET=your-nextauth-secret-here

# ===== Next.js (public vars baked into the app at build time) =====
# This URL must be reachable from the browser (e.g., http://localhost for local, or your public domain in production)
NEXT_PUBLIC_API_URL=http://localhost

# Internal API URL for server-side calls (NextAuth authorize function)
# In Docker: http://api:8080 (web container calls API directly via Docker network)
# In local dev: http://localhost:8080 (bypasses Caddy, calls API directly)
API_INTERNAL_URL=http://api:8080
